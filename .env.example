# Variables de entorno — Comprobar
# Copiar este archivo como .env en backend/ y frontend/ y completar los valores reales.
# NUNCA commitear .env con valores reales.

# ==============================
# OpenAI
# ==============================
OPENAI_API_KEY=

# ==============================
# Supabase
# ==============================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==============================
# JWT (firmado en el backend para sesiones custom si se usan)
# ==============================
JWT_SECRET=

# ==============================
# Entorno
# ==============================
NODE_ENV=development

# ==============================
# Monitoreo de errores
# ==============================
SENTRY_DSN=

# ==============================
# URLs de los servicios
# ==============================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ==============================
# Modelo de OpenAI (configurable)
# ==============================
OPENAI_MODEL=gpt-4o
